{
  "name": "volta-next-typescript-knex-postgress",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run db:migrate && next dev",
    "build": "next build --webpack", 
    "start": "next start",
    "lint": "next lint",
    "db:migrate": "knex migrate:latest --knexfile knexfile.ts",
    "test": "vitest",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "knex": "^3.2.10",
    "next": "16.2.4",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/knex": "^0.15.2",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "coveralls": "^3.1.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
